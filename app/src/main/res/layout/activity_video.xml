<?xml version="1.0" encoding="utf-8"?>
<!-- Root FrameLayout lets the fullscreen container overlay everything -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Normal player layout -->
    <LinearLayout
        android:id="@+id/layout_normal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_video"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primaryColor"
            android:elevation="4dp"
            app:titleTextColor="@color/white"
            app:navigationIconTint="@color/white" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <WebView
                android:id="@+id/web_view_player"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hardwareAccelerated="true" />

            <ProgressBar
                android:id="@+id/video_progress"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/accentColor" />

        </FrameLayout>

    </LinearLayout>

    <!-- Fullscreen container — shown when Drive video player goes fullscreen in landscape -->
    <FrameLayout
        android:id="@+id/fullscreen_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone" />

</FrameLayout>
