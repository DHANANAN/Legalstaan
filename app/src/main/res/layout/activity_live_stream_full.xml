<?xml version="1.0" encoding="utf-8"?>
<!-- Root FrameLayout so fullscreen container can overlay the toolbar -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Normal stream layout -->
    <LinearLayout
        android:id="@+id/layout_live_normal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_live"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primaryColor"
            android:elevation="4dp"
            app:titleTextColor="@color/white"
            app:navigationIconTint="@color/white" />

        <WebView
            android:id="@+id/webview_live"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hardwareAccelerated="true" />

    </LinearLayout>

    <!-- Fullscreen overlay for landscape video mode -->
    <FrameLayout
        android:id="@+id/fullscreen_live_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone" />

</FrameLayout>
