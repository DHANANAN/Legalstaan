<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Profile header card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorSurface"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="84dp"
                android:layout_height="84dp">

                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:background="@drawable/circle_avatar_bg"
                    android:contentDescription="Profile photo"
                    android:padding="16dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_nav_profile"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Edit badge -->
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:background="@color/accentColor"
                    android:contentDescription="Edit photo"
                    android:padding="5dp"
                    android:src="@android:drawable/ic_menu_edit" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_change_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Change Photo"
                android:textColor="@color/accentColor"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/profile_name"
                android:textColor="@color/colorBodyText"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_profile_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/colorSecondaryText"
                android:textSize="13sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@color/colorBackground" />

        <!-- Menu rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorSurface"
            android:orientation="vertical">

            <include layout="@layout/item_profile_row" android:id="@+id/row_payments" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorDivider" />
            <include layout="@layout/item_profile_row" android:id="@+id/row_certificates" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorDivider" />
            <include layout="@layout/item_profile_row" android:id="@+id/row_downloads" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorDivider" />
            <include layout="@layout/item_profile_row" android:id="@+id/row_free_material" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorDivider" />
            <include layout="@layout/item_profile_row" android:id="@+id/row_settings" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorDivider" />

            <!-- Dark mode toggle row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dark Mode"
                    android:textColor="@color/colorBodyText"
                    android:textSize="15sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_dark_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorDivider" />
            <include layout="@layout/item_profile_row" android:id="@+id/row_how_to" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorDivider" />
            <include layout="@layout/item_profile_row" android:id="@+id/row_privacy" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorDivider" />
            <include layout="@layout/item_profile_row" android:id="@+id/row_sign_out" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:background="@color/colorBackground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="© 2026 Legalstaan · v1.33"
            android:textSize="11sp"
            android:textColor="@color/colorSecondaryText"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
