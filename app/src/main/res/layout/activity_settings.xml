<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_settings"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primaryColor"
        android:elevation="4dp"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/white"
        app:titleTextColor="@color/white" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- Section: Appearance -->
            <TextView
                style="@style/SettingsHeader"
                android:text="Appearance" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="Dark Mode" />

                            <TextView
                                style="@style/SettingsRowSubtitle"
                                android:text="Easier on the eyes after sundown" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/sw_dark_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Support -->
            <TextView
                style="@style/SettingsHeader"
                android:text="Support" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/row_contact"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@android:drawable/sym_action_email"
                            app:tint="@color/primaryColor" />

                        <LinearLayout style="@style/SettingsRowText">
                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="Contact Support" />
                            <TextView
                                style="@style/SettingsRowSubtitle"
                                android:text="contactlegalstaan@gmail.com" />
                        </LinearLayout>

                        <ImageView style="@style/SettingsRowChevron" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/row_share"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@android:drawable/ic_menu_share"
                            app:tint="@color/primaryColor" />

                        <LinearLayout style="@style/SettingsRowText">
                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="Share App" />
                            <TextView
                                style="@style/SettingsRowSubtitle"
                                android:text="Tell your peers about Legalstaan" />
                        </LinearLayout>

                        <ImageView style="@style/SettingsRowChevron" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/row_rate"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@android:drawable/btn_star_big_on"
                            app:tint="@color/accentColor" />

                        <LinearLayout style="@style/SettingsRowText">
                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="Rate Us" />
                            <TextView
                                style="@style/SettingsRowSubtitle"
                                android:text="Leave a review on the Play Store" />
                        </LinearLayout>

                        <ImageView style="@style/SettingsRowChevron" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Storage -->
            <TextView
                style="@style/SettingsHeader"
                android:text="Storage" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout
                    android:id="@+id/row_clear_cache"
                    style="@style/SettingsRow">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@android:drawable/ic_menu_delete"
                        app:tint="@color/primaryColor" />

                    <LinearLayout style="@style/SettingsRowText">
                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="Clear Cache" />
                        <TextView
                            style="@style/SettingsRowSubtitle"
                            android:text="Free up local storage" />
                    </LinearLayout>

                    <ImageView style="@style/SettingsRowChevron" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Legal -->
            <TextView
                style="@style/SettingsHeader"
                android:text="Legal" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/row_privacy"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@android:drawable/ic_lock_lock"
                            app:tint="@color/primaryColor" />

                        <LinearLayout style="@style/SettingsRowText">
                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="Privacy Policy" />
                            <TextView
                                style="@style/SettingsRowSubtitle"
                                android:text="How we handle your data" />
                        </LinearLayout>

                        <ImageView style="@style/SettingsRowChevron" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/row_terms"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="@color/primaryColor" />

                        <LinearLayout style="@style/SettingsRowText">
                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="Terms of Service" />
                            <TextView
                                style="@style/SettingsRowSubtitle"
                                android:text="Rules of using Legalstaan" />
                        </LinearLayout>

                        <ImageView style="@style/SettingsRowChevron" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/row_about"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="@color/primaryColor" />

                        <LinearLayout style="@style/SettingsRowText">
                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="About Legalstaan" />
                            <TextView
                                style="@style/SettingsRowSubtitle"
                                android:text="Visit legalstaan.com" />
                        </LinearLayout>

                        <ImageView style="@style/SettingsRowChevron" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- App version footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Version"
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_version_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="v1.29.0"
                    android:textColor="@color/colorBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="© 2026 Legalstaan. All rights reserved."
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
