<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Empty state shown when no live sessions -->
    <LinearLayout
        android:id="@+id/layout_empty_live"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_nav_live"
            app:tint="@color/colorSecondaryText"
            android:alpha="0.35"
            android:contentDescription="No live sessions" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="No Live Sessions Right Now"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorHeadingText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="When a faculty member starts a live class, it will appear here automatically."
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/colorSecondaryText" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_live_sessions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <!-- Faculty-only FAB to start a live session -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_go_live"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="Go Live"
        android:textColor="@color/white"
        app:icon="@drawable/ic_nav_live"
        app:iconTint="@color/white"
        app:backgroundTint="@color/primaryColor"
        android:visibility="gone"
        android:contentDescription="Start live session" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
