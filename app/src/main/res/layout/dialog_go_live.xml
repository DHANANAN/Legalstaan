<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Session Title"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/colorHeadingText"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/et_session_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. Patent Law – Chapter 5"
        android:inputType="textCapWords"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Streaming Platform"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/colorHeadingText"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_platform"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/rb_jitsi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Jitsi Meeting (in-app, no account needed)"
            android:textSize="13sp" />

        <RadioButton
            android:id="@+id/rb_youtube"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YouTube Live (paste your stream URL)"
            android:textSize="13sp" />

        <RadioButton
            android:id="@+id/rb_google_meet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Google Meet (backup — paste meeting link)"
            android:textSize="13sp" />

    </RadioGroup>

    <!-- Shown only when YouTube is selected -->
    <LinearLayout
        android:id="@+id/layout_youtube_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YouTube Live URL"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/colorHeadingText"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_youtube_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://youtube.com/watch?v=..."
            android:inputType="textUri"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start your YouTube Live stream first, then paste the URL here."
            android:textSize="11sp"
            android:textColor="@color/colorSecondaryText"
            android:layout_marginBottom="4dp" />

    </LinearLayout>

    <!-- Shown only when Google Meet is selected -->
    <LinearLayout
        android:id="@+id/layout_meet_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Google Meet Link"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/colorHeadingText"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_meet_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://meet.google.com/abc-defg-hij"
            android:inputType="textUri"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create a Google Meet first, then paste the join link here. Students will open it in their browser."
            android:textSize="11sp"
            android:textColor="@color/colorSecondaryText"
            android:layout_marginBottom="4dp" />

    </LinearLayout>

</LinearLayout>
