<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <ImageView
            android:id="@+id/login_logo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/app_icon"
            android:layout_marginBottom="20dp"
            android:contentDescription="Legalstaan Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to Legalstaan"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/colorHeadingText"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Legal Learning Partner"
            android:textSize="14sp"
            android:textColor="@color/colorSecondaryText"
            android:layout_marginBottom="40dp" />

        <!-- Google Sign-In -->
        <com.google.android.gms.common.SignInButton
            android:id="@+id/btn_google_sign_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/colorDivider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:text="or"
                android:textColor="@color/colorSecondaryText"
                android:textSize="13sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/colorDivider" />

        </LinearLayout>

        <!-- Email / Password fields -->
        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email address"
            android:inputType="textEmailAddress"
            android:background="@color/colorSurface"
            android:textColor="@color/colorBodyText"
            android:textColorHint="@color/colorSecondaryText"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password (min 6 chars)"
            android:inputType="textPassword"
            android:background="@color/colorSurface"
            android:textColor="@color/colorBodyText"
            android:textColorHint="@color/colorSecondaryText"
            android:padding="14dp"
            android:layout_marginBottom="14dp"
            android:singleLine="true" />

        <Button
            android:id="@+id/btn_email_auth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign In"
            android:backgroundTint="@color/accentColor"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_toggle_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New here? Create an account"
            android:textColor="@color/accentColor"
            android:textSize="13sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="24dp" />

        <ProgressBar
            android:id="@+id/login_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/accentColor"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
