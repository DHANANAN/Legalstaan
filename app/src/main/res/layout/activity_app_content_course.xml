<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_app_content_course"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primaryColor"
        android:elevation="4dp"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/white"
        app:titleTextColor="@color/white"
        app:title="App Content Course" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ============================================================ -->
            <!-- LOCKED STATE                                                  -->
            <!-- ============================================================ -->
            <LinearLayout
                android:id="@+id/section_locked"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <!-- Hero strip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primaryColor"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="Locked"
                        android:src="@android:drawable/ic_lock_lock"
                        app:tint="@color/accentColor" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="PREMIUM · LOCKED"
                            android:textAllCaps="true"
                            android:textColor="@color/accentColor"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="App Content Course"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Curated lectures, notes &amp; drills on Drive"
                            android:textColor="#CCCCCC"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Pricing card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_pricing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/colorCardStroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="COURSE FEE"
                            android:textAllCaps="true"
                            android:textColor="@color/colorSecondaryText"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_mrp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="₹51"
                            android:textColor="@color/colorSecondaryText"
                            android:textSize="18sp" />

                        <LinearLayout
                            android:id="@+id/row_discount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="Coupon"
                                android:src="@android:drawable/ic_menu_save"
                                app:tint="@color/accentColor" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="Coupon FLASHSALE applied"
                                android:textColor="@color/colorBodyText"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="−₹40"
                                android:textColor="#1B5E20"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/row_coupon_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Enter coupon code"
                                app:boxStrokeColor="@color/primaryColor"
                                app:hintTextColor="@color/colorSecondaryText">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_coupon"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:imeOptions="actionDone"
                                    android:inputType="textCapCharacters|textNoSuggestions"
                                    android:maxLength="16"
                                    android:textColor="@color/colorBodyText"
                                    android:textSize="15sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_apply_coupon"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:backgroundTint="@color/accentColor"
                                android:text="Apply"
                                android:textColor="@color/primaryColor"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/row_coupon_applied"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/coupon_applied_bg"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✓"
                                android:textColor="#1B5E20"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="FLASHSALE applied — ₹40 off"
                                android:textColor="#1B5E20"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_coupon_remove"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:padding="4dp"
                                android:text="Remove"
                                android:textColor="#1B5E20"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="12dp"
                            android:background="@color/colorDivider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="You pay"
                                android:textColor="@color/colorBodyText"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_final_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹51"
                                android:textColor="@color/primaryColor"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_coupon_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Tip: enter coupon code FLASHSALE to unlock the discount"
                            android:textColor="@color/colorSecondaryText"
                            android:textSize="11sp"
                            android:textStyle="italic" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Payment portal CTA -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_continue_payment"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="@color/primaryColor"
                    android:letterSpacing="0.04"
                    android:text="Continue to Payment"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:icon="@android:drawable/ic_lock_lock"
                    app:iconGravity="textStart"
                    app:iconTint="@color/accentColor" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="Secure UPI payment • Powered by Legalstaan"
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="11sp" />

                <!-- Payment section, revealed by the CTA -->
                <LinearLayout
                    android:id="@+id/section_payment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="10dp"
                        android:letterSpacing="0.06"
                        android:text="SCAN &amp; PAY"
                        android:textAllCaps="true"
                        android:textColor="@color/colorSecondaryText"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"
                        app:cardBackgroundColor="@color/colorSurface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeColor="@color/colorCardStroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <ImageView
                                android:layout_width="280dp"
                                android:layout_height="380dp"
                                android:adjustViewBounds="true"
                                android:contentDescription="UPI QR — krishnashelkeintern@oksbi"
                                android:scaleType="fitCenter"
                                android:src="@drawable/join_batch_qr" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Scan with any UPI app"
                                android:textColor="@color/colorHeadingText"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="krishnashelkeintern@oksbi · Krishna Panditrao Shelke"
                                android:textColor="@color/colorSecondaryText"
                                android:textSize="11sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_open_upi_app"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Open UPI app"
                                android:textColor="@color/primaryColor"
                                app:icon="@android:drawable/sym_action_email"
                                app:iconTint="@color/primaryColor" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Why no auto-confirm -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:text="RBI rules prevent us from auto-confirming UPI payments. After scanning, use one of the options below to unlock the course."
                        android:textColor="@color/colorSecondaryText"
                        android:textSize="11sp"
                        android:textStyle="italic" />

                    <!-- Unlock options header -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="10dp"
                        android:letterSpacing="0.06"
                        android:text="CONFIRM &amp; UNLOCK"
                        android:textAllCaps="true"
                        android:textColor="@color/colorSecondaryText"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"
                        app:cardBackgroundColor="@color/colorSurface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeColor="@color/colorCardStroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Option A: simulated return -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A · I've completed the payment"
                                android:textColor="@color/colorBodyText"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Tap after returning from your UPI app. We'll trust you for this demo run."
                                android:textColor="@color/colorSecondaryText"
                                android:textSize="11sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_simulated_return"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:backgroundTint="@color/primaryColor"
                                android:text="I've completed the payment"
                                android:textColor="@color/white" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="16dp"
                                android:layout_marginBottom="14dp"
                                android:background="@color/colorDivider" />

                            <!-- Option B: admin override -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="B · Mark as Paid (Tester / Admin)"
                                android:textColor="@color/colorBodyText"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Faculty + internal testers can unlock without a UPI run."
                                android:textColor="@color/colorSecondaryText"
                                android:textSize="11sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_admin_toggle"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Mark as Paid (admin override)"
                                android:textColor="@color/primaryColor" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="16dp"
                                android:layout_marginBottom="14dp"
                                android:background="@color/colorDivider" />

                            <!-- Option C: txn ref -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="C · Enter txn reference (last 6 digits)"
                                android:textColor="@color/colorBodyText"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="We store the txn ref with your receipt so faculty can match it later."
                                android:textColor="@color/colorSecondaryText"
                                android:textSize="11sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/til_txn_ref"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:hint="Last 6 digits"
                                    app:boxStrokeColor="@color/primaryColor"
                                    app:hintTextColor="@color/colorSecondaryText">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/et_txn_ref"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:imeOptions="actionDone"
                                        android:inputType="number"
                                        android:maxLength="6"
                                        android:textColor="@color/colorBodyText"
                                        android:textSize="15sp" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_submit_txn"
                                    style="@style/Widget.MaterialComponents.Button"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:backgroundTint="@color/accentColor"
                                    android:text="Verify"
                                    android:textColor="@color/primaryColor"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
                <!-- /section_payment -->

            </LinearLayout>
            <!-- /section_locked -->

            <!-- ============================================================ -->
            <!-- UNLOCKED STATE                                                -->
            <!-- ============================================================ -->
            <LinearLayout
                android:id="@+id/section_unlocked"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp"
                android:visibility="gone">

                <!-- Success hero -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0D4F2C"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:contentDescription="Unlocked"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="#7CFFB4" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="ENROLLED · UNLOCKED"
                            android:textAllCaps="true"
                            android:textColor="#7CFFB4"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="App Content Course"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Receipt summary -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/colorCardStroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="PAYMENT RECEIPT"
                            android:textAllCaps="true"
                            android:textColor="@color/colorSecondaryText"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_receipt_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Paid ₹11 · coupon FLASHSALE"
                            android:textColor="@color/colorBodyText"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Open course content -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_course"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="@color/primaryColor"
                    android:letterSpacing="0.04"
                    android:text="Open Course Materials"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:icon="@android:drawable/ic_menu_view"
                    app:iconGravity="textStart"
                    app:iconTint="@color/accentColor" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_payments"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="10dp"
                    android:text="View Payments &amp; Receipts"
                    android:textColor="@color/primaryColor" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="Course materials open via the same Drive viewer used for free study materials — new uploads sync automatically."
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="11sp"
                    android:textStyle="italic" />

            </LinearLayout>
            <!-- /section_unlocked -->

        </FrameLayout>
